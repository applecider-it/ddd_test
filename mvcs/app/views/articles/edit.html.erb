<% content_for :title, "Editing article" %>

<h1>Editing article</h1>

<%= form_with(model: @article, url: article_path(@article.id), scope: :article, method: :put) do |form| %>
  <%= render "form", article: @article, form: form %>

  <div>
    <%= form.submit "更新" %>
  </div>
<% end %>

<br>

<div>
  <%= link_to "Show this article", article_path(@article) %> |
  <%= link_to "Back to articles", articles_path %>
</div>
